\begin_layout Subsection
Distributions
\end_layout

\begin_layout Itemize
\begin_inset Formula $\text{IG}(a,b)$
\end_inset

 is the distribution with pdf 
\begin_inset Formula 
\[
f(x;a,b)=\frac{b^{a}}{\Gamma(a)}\frac{1}{x^{a+1}}e^{-b/x}.
\]

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
Note that as 
\begin_inset Formula $a,b\to0$
\end_inset

 then this converges to a pdf proportional to 
\begin_inset Formula $1/x$
\end_inset

.
 
\end_layout

\begin_layout Itemize
The mean is 
\begin_inset Formula $b/(a-1)$
\end_inset

.
 
\end_layout

\end_deeper
\begin_layout Itemize
\begin_inset Formula $\mathfrak{t}_{p}(\boldsymbol{\mu},\boldsymbol{\Sigma},\nu)$
\end_inset

 denotes a 
\begin_inset Formula $p$
\end_inset

-dimension multivariate 
\begin_inset Formula $t$
\end_inset

 distribution with mean and variance 
\begin_inset Formula $\boldsymbol{\mu},\boldsymbol{\Sigma}$
\end_inset

,
 and 
\begin_inset Formula $\nu$
\end_inset

 degrees of freedom.
\end_layout

\begin_layout Itemize
\begin_inset Formula $\mathcal{N}_{p}(\boldsymbol{\mu},\boldsymbol{\Sigma})$
\end_inset

 denotes a 
\begin_inset Formula $p$
\end_inset

-dimension multivariate normal distribution with mean and variance 
\begin_inset Formula $\boldsymbol{\mu},\boldsymbol{\Sigma}$
\end_inset

.
 
\end_layout

\begin_layout Subsubsection
Regression problem
\end_layout

\begin_layout Standard
Suppose 
\begin_inset Formula $y\in\mathbb{R}^{n}$
\end_inset

 and 
\begin_inset Formula $X\in\mathbb{R}^{n\times p}$
\end_inset

.
 We are going to assume that 
\begin_inset Formula 
\[
y|_{x}\,\,\sim_{\text{iid}}\,\,\mathcal{N}_{1}\left(x^{\top}\beta,\sigma^{2}\right).
\]

\end_inset

The likelihood is therefore 
\begin_inset Formula 
\begin{align*}
\pi\left(y\mid X,\beta,\sigma^{2}\right) & =\prod_{i}\frac{1}{\sqrt{2\pi\sigma^{2}}}\exp\left\{ -\frac{1}{2}\frac{\left(y_{i}-x_{i}^{\top}\beta\right)^{2}}{\sigma^{2}}\right\} \\
 & =\left(\frac{1}{2\pi\sigma^{2}}\right)^{n/2}\exp\left\{ -\frac{1}{2\sigma^{2}}\,\text{SSR}\left(\beta\mid y,X\right)\right\} 
\end{align*}

\end_inset

where 
\begin_inset Formula $\text{SSR}\left(\beta\mid y,X\right)=\sum_{i}\left(y_{i}-x_{i}^{\top}\beta\right)^{2}$
\end_inset

.
 
\end_layout

\begin_layout Standard
We then apply a prior 
\begin_inset Formula $\pi(\beta,\sigma^{2})$
\end_inset

 to form a posterior 
\begin_inset Formula 
\begin{align*}
\pi(\beta,\sigma^{2}\mid y,X) & \propto\pi(\beta,\sigma^{2})\times\pi(y\mid X,\beta,\sigma^{2}).
\end{align*}

\end_inset


\end_layout

\begin_layout Section
Analytically Tractable Priors
\end_layout

\begin_layout Subsection
Normal-Inverse-Gaussian (NIG)
\end_layout

\begin_layout Standard
Assume a prior 
\begin_inset Formula 
\begin{align*}
\sigma^{2} & \sim\text{IG}(a_{0},b_{0})\\
\beta|_{\sigma^{2}} & \sim\mathcal{N}_{p}\left(\boldsymbol{\mu}_{0},\sigma^{2}\boldsymbol{\Lambda}_{0}^{-1}\right)
\end{align*}

\end_inset

Then we update the posterior as follows:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{eqnarray*}
\boldsymbol{\Lambda}_{0} & \to & \hat{\boldsymbol{\Lambda}}=X^{\top}X+\boldsymbol{\Lambda}_{0}\\
\boldsymbol{\mu}_{0} & \to & \hat{\boldsymbol{\mu}}=\hat{\boldsymbol{\Lambda}}^{-1}\left(X^{\top}y+\boldsymbol{\Lambda}_{0}\boldsymbol{\mu}_{0}\right)\\
a_{0} & \to & \hat{a}=a_{0}+\frac{n}{2}\qquad(\text{SHOULD THIS BE }\frac{n-p}{2})??\\
b_{0} & \to & \hat{b}=b_{0}+\frac{1}{2}\left(y^{\top}y+\boldsymbol{\mu}_{0}^{\top}\boldsymbol{\Lambda}_{0}\boldsymbol{\mu}_{0}-\hat{\boldsymbol{\mu}}^{\top}\hat{\boldsymbol{\Lambda}}\hat{\boldsymbol{\mu}}\right)
\end{eqnarray*}

\end_inset

You sometimes see the parametrization 
\begin_inset Formula $a=\frac{1}{2}\nu,b=\frac{1}{2}\nu\sigma_{0}^{2}$
\end_inset

,
 which implies a distribution on the prior with 
\begin_inset Formula 
\[
E[\sigma^{2}]=\frac{\nu}{\nu-2}\sigma_{0}^{2},\qquad V[\sigma^{2}]=\frac{\frac{1}{4}\nu^{2}}{(\frac{1}{2}\nu-1)^{2}(\frac{1}{2}\nu-2)}\sigma_{0}^{2}.
\]

\end_inset

You can see that as 
\begin_inset Formula $\nu\to\infty$
\end_inset

 the mean goes 
\begin_inset Formula $\sigma_{0}^{2}$
\end_inset

 and the variance goes to zero (since you have squared over cubed).
 So 
\begin_inset Formula $\sigma_{0}^{2}$
\end_inset

 is our 
\begin_inset Quotes eld
\end_inset

guess
\begin_inset Quotes erd
\end_inset

 on the scale and 
\begin_inset Formula $\nu$
\end_inset

 is our 
\begin_inset Quotes eld
\end_inset

confidence
\begin_inset Quotes erd
\end_inset

.
 
\end_layout

\begin_layout Subsubsection
Marginal Posteriors
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{eqnarray*}
\sigma^{2}\mid_{y,X} & \sim & \text{IG}(\hat{a},\hat{b})\\
\beta^{2}\mid_{y,X} & \sim & \mathcal{\mathfrak{t}}_{p}\left(\hat{\mu},\frac{\hat{b}}{\hat{a}}\hat{\boldsymbol{\Lambda}}^{-1},2\hat{a}\right)
\end{eqnarray*}

\end_inset


\end_layout

\begin_layout Subsubsection
Conditional Posteriors
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\beta|_{\sigma^{2},y,X} & \sim\mathcal{N}_{p}\left(\hat{\mu},\sigma^{2}\hat{\boldsymbol{\Lambda}}^{-1}\right)\\
\sigma^{2}|_{\beta,y,X} & \sim\text{IG}\left(a_{0}+\frac{n+2}{2},b_{0}+\frac{1}{2}\left(y-X\beta\right)^{\top}\left(y-X\beta\right)+\frac{1}{2}\left(\beta-\boldsymbol{\mu}_{0}\right)^{\top}\boldsymbol{\Lambda}_{0}\left(\beta-\boldsymbol{\mu}_{0}\right)\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Subsection
Diffuse (Jeffrey's Prior)
\end_layout

\begin_layout Standard
Assume a prior 
\begin_inset Formula $\pi(\beta,\sigma^{2})\propto1/\sigma^{2}$
\end_inset

.
 Then
\end_layout

\begin_layout Subsubsection
Marginal Posteriors
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\beta|_{X,y}\sim\mathfrak{t}_{p+1}\left(\hat{\beta},\hat{\Sigma},t-p\right)
\]

\end_inset

where 
\begin_inset Formula 
\begin{align*}
\hat{\beta} & =\left(X^{\top}X\right)^{-1}X^{\top}y\\
\hat{\sigma}^{2} & =\frac{\left(y-X\hat{\beta}\right)^{\top}\left(y-X\hat{\beta}\right)}{n}\\
\hat{\Sigma} & =\hat{\sigma}^{2}(X^{\top}X)^{-1}
\end{align*}

\end_inset

and 
\begin_inset Formula 
\[
\sigma^{2}|_{X,y}\sim\text{IG}\left(\frac{n-p}{2},\frac{n}{2}\hat{\sigma}^{2}\right).
\]

\end_inset

Note that 
\begin_inset Formula $\hat{\beta},\hat{\sigma}$
\end_inset

 are the MAP estimates.
\end_layout

\begin_layout Subsubsection
Conditional Posteriors
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\beta|_{\sigma^{2},y,X} & \sim\mathcal{N}_{p}\left(\hat{\beta},\sigma^{2}\left(X^{\top}X\right)^{-1}\right)\\
\sigma^{2}|_{\beta,y,X} & \sim\text{IG}\left(\frac{n}{2},\frac{n}{2}\hat{\sigma}^{2}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection
Joint Posterior
\begin_inset Formula 
\[
\beta,\sigma^{2}|_{y,X}\propto\mathcal{N}_{p}\left(\hat{\beta},\sigma^{2}\left(X^{\top}X\right)^{-1}\right)\times\text{IG}\left(\frac{n-p}{2},\frac{n}{2}\hat{\sigma}^{2}\right)
\]

\end_inset


\end_layout

\begin_layout Section
Connection to Ridge Regression
\end_layout

\begin_layout Standard
The Bayesian Linear Regression with the prior 
\begin_inset Formula 
\[
\beta|_{\sigma^{2}}\sim\mathcal{N}\left(\mu,\sigma^{2}\,\text{Diag}(\{\lambda_{k}^{-1}\}_{k})\right)
\]

\end_inset

is equivalent to the Ridge regression
\begin_inset Formula 
\[
\min_{\beta}\,\,\,\frac{1}{2n}\sum_{i}w_{i}\left(y_{i}-x_{i}'\beta\right)^{2}+\sum_{k}\frac{\tilde{\lambda}_{k}}{2}\left(\beta_{k}-\bar{\beta}_{k}\right)^{2}.
\]

\end_inset

where 
\begin_inset Formula $\tilde{\lambda}_{k}=\lambda_{k}/\left(\sum_{i}w_{i}\right)$
\end_inset

 ,
 where 
\begin_inset Formula $w_{i}$
\end_inset

 are the weights.
\end_layout

