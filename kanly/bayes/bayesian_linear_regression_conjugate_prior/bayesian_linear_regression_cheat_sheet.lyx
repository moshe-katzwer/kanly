\begin_layout Section
Appendix:
 Derivation
\end_layout

\begin_layout Standard
Suppose 
\begin_inset Formula $\sigma^{2}\sim\text{InvGamma}(a_{0},b_{0})$
\end_inset

 and 
\begin_inset Formula $\beta|_{\sigma^{2}}\sim\mathcal{N}\left(\mu_{0},\sigma^{2}\Lambda_{0}^{-1}\right)$
\end_inset

.
 This suggests a posterior of the form 
\begin_inset Formula 
\begin{eqnarray*}
p\left(\beta,\sigma^{2}\mid y\right) & \propto & \frac{b_{0}^{a_{0}}}{\Gamma(a_{0})}\frac{1}{(\sigma^{2})^{a+1}}e^{-b_{0}/\sigma_{2}}\\
 &  & \qquad\times(2\pi)^{-p/2}\det\left(\sigma^{2}\Lambda_{0}^{-1}\right)^{-1/2}\exp\left\{ -\frac{1}{2\sigma^{2}}\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)\right\} \\
 &  & \qquad\times(2\pi)^{-n/2}\det\left(\sigma^{2}I_{n}\right)^{-1/2}\exp\left\{ -\frac{1}{2\sigma^{2}}\left(y-X\beta\right)^{\top}\left(y-X\beta\right)\right\} 
\end{eqnarray*}

\end_inset

Grouping the exponential terms,
 
\begin_inset Formula 
\begin{align*}
 & \exp\left\{ -\frac{1}{2\sigma^{2}}\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)\right\} \exp\left\{ -\frac{1}{2\sigma^{2}}\left(y-X\beta\right)^{\top}\left(y-X\beta\right)\right\} \\
= & \exp\left\{ -\frac{1}{2\sigma^{2}}\left[\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)+\left(y-X\beta\right)^{\top}\left(y-X\beta\right)\right]\right\} \\
= & \exp\left\{ -\frac{1}{2\sigma^{2}}\left[\beta^{\top}\Lambda_{0}\beta-2\beta^{\top}\Lambda_{0}\mu_{0}-\mu_{0}^{\top}\Lambda_{0}\mu_{0}+y^{\top}y-2y^{\top}X\beta+\beta^{\top}X^{\top}X\beta\right]\right\} \\
= & \exp\left\{ -\frac{1}{2\sigma^{2}}\left[\beta^{\top}\left(\Lambda_{0}+X^{\top}X\right)\beta-2\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\beta-\mu_{0}^{\top}\Lambda_{0}\mu_{0}+y^{\top}y\right]\right\} 
\end{align*}

\end_inset

Now,
 let 
\begin_inset Formula $\mu_{n}=\left(\Lambda_{0}+X^{\top}X\right)^{-1}\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)$
\end_inset

,
 note that this maximizes the quadratic form in the exponential.
 Now,
 note that 
\begin_inset Formula 
\begin{align*}
\left(\beta-\mu_{n}\right)^{\top}\left(\Lambda_{0}+X^{\top}X\right)\left(\beta-\mu_{n}\right) & =\beta^{\top}\left(\Lambda_{0}+X^{\top}X\right)\beta-2\mu_{n}^{\top}\left(\Lambda_{0}+X^{\top}X\right)\beta+\mu_{n}^{\top}\left(\Lambda_{0}+X^{\top}X\right)\mu_{n}\\
\left(\beta-\mu_{n}\right)^{\top}\left(\Lambda_{0}+X^{\top}X\right)\left(\beta-\mu_{n}\right) & =\beta^{\top}\left(\Lambda_{0}+X^{\top}X\right)\beta-2\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\beta+\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\left(\Lambda_{0}+X^{\top}X\right)^{-1}\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\\
\beta^{\top}\left(\Lambda_{0}+X^{\top}X\right)\beta & =\left(\beta-\mu_{n}\right)^{\top}\left(\Lambda_{0}+X^{\top}X\right)\left(\beta-\mu_{n}\right)+2\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\beta-\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\left(\Lambda_{0}+X^{\top}X\right)^{-1}\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)
\end{align*}

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
\beta^{\top}\left(\Lambda_{0}+X^{\top}X\right)\beta-2\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\beta-\mu_{0}^{\top}\Lambda_{0}\mu_{0}+y^{\top}y & = & \left(\beta-\mu_{n}\right)^{\top}\left(\Lambda_{0}+X^{\top}X\right)\left(\beta-\mu_{n}\right)+2\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\beta\\
 &  & -\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\left(\Lambda_{0}+X^{\top}X\right)^{-1}\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\\
 &  & -2\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\beta-\mu_{0}^{\top}\Lambda_{0}\mu_{0}+y^{\top}y\\
 & = & \left(\beta-\mu_{n}\right)^{\top}\left(\Lambda_{0}+X^{\top}X\right)\left(\beta-\mu_{n}\right)\\
 &  & -\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\mu_{n}-\mu_{0}^{\top}\Lambda_{0}\mu_{0}+y^{\top}y
\end{eqnarray*}

\end_inset

Now
\begin_inset Formula 
\begin{align*}
\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right) & =\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\left(\Lambda_{0}+X^{\top}X\right)^{-1}\left(\Lambda_{0}+X^{\top}X\right)\\
 & =\mu_{n}^{\top}\left(\Lambda_{0}+X^{\top}X\right)
\end{align*}

\end_inset

So 
\begin_inset Formula 
\[
\beta^{\top}\left(\Lambda_{0}+X^{\top}X\right)\beta-2\left(\mu_{0}^{\top}\Lambda_{0}+y^{\top}X\right)\beta-\mu_{0}^{\top}\Lambda_{0}\mu_{0}+y^{\top}y=\left(\beta-\mu_{n}\right)^{\top}\left(\Lambda_{0}+X^{\top}X\right)\left(\beta-\mu_{n}\right)-\mu_{n}^{\top}\left(\Lambda_{0}+X^{\top}X\right)\mu_{n}-\mu_{0}^{\top}\Lambda_{0}\mu_{0}+y^{\top}y
\]

\end_inset

Finally,
 define 
\begin_inset Formula $\Lambda_{n}=\Lambda_{0}+X^{\top}X$
\end_inset

.
 Then the quadratic form becomes
\begin_inset Formula 
\[
\left(\beta-\mu_{n}\right)^{\top}\Lambda_{n}\left(\beta-\mu_{n}\right)-\mu_{n}^{\top}\Lambda_{n}\mu_{n}-\mu_{0}^{\top}\Lambda_{0}\mu_{0}+y^{\top}y
\]

\end_inset

and we can now rewrite the posterior as 
\begin_inset Formula 
\begin{eqnarray*}
p\left(\beta,\sigma^{2}\mid y\right) & \propto & \frac{b_{0}^{a_{0}}}{\Gamma(a_{0})}\frac{1}{(\sigma^{2})^{a+1}}\exp\left\{ -b_{0}/\sigma_{2}\right\} \\
 &  & \qquad\times(2\pi)^{-p/2}\det\left(\sigma^{2}\Lambda_{0}^{-1}\right)^{-1/2}\\
 &  & \qquad\times(2\pi)^{-n/2}\det\left(\sigma^{2}I_{n}\right)^{-1/2}\times\exp\left\{ -\frac{\left(\beta-\mu_{n}\right)^{\top}\Lambda_{n}\left(\beta-\mu_{n}\right)}{2\sigma^{2}}\right\} \exp\left\{ \frac{y^{\top}y-\mu_{n}^{\top}\Lambda_{n}\mu_{n}+\mu_{0}^{\top}\Lambda_{0}\mu_{0}}{2\sigma^{2}}\right\} 
\end{eqnarray*}

\end_inset

It's now clear that in the posterior,
 
\begin_inset Formula $\beta|_{\sigma^{2}}\sim\mathcal{N}\left(\mu_{n}\sigma^{2}\Lambda_{n}^{-1}\right)$
\end_inset

.
 Taking the log,
 we have 
\begin_inset Formula 
\begin{eqnarray*}
p\left(\beta,\sigma^{2}\mid y\right) & \propto & \frac{b_{0}^{a_{0}}}{\Gamma(a_{0})}\frac{1}{(\sigma^{2})^{a+1}}\exp\left\{ -b_{0}/\sigma_{2}\right\} \\
 &  & \qquad\times(2\pi)^{-p/2}\det\left(\sigma^{2}\Lambda_{0}^{-1}\right)^{-1/2}\\
 &  & \qquad\times(2\pi)^{-n/2}\det\left(\sigma^{2}I_{n}\right)^{-1/2}\times+\left\{ \frac{\left(\beta-\mu_{n}\right)^{\top}\Lambda_{n}\left(\beta-\mu_{n}\right)}{2\sigma^{2}}\right\} +\left\{ \frac{-\mu_{n}^{\top}\Lambda_{n}\mu_{n}-\mu_{0}^{\top}\Lambda_{0}\mu_{0}+y^{\top}y}{2\sigma^{2}}\right\} 
\end{eqnarray*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\pi(\sigma^{2}) & =\frac{b^{a}}{\Gamma(a)}\frac{1}{(\sigma^{2})^{a+1}}e^{-b/\sigma^{2}}\\
 & \propto\frac{1}{(\sigma^{2})^{a+1}}e^{-b/\sigma^{2}}\\
\log\pi(\sigma^{2}) & \propto-s(a+1)\log\sigma^{2}-\frac{b}{\sigma^{2}}\\
\pi(\beta|\sigma^{2}) & \propto\exp\left\{ -\frac{1}{2\sigma^{2}}(\beta-\mu)\Lambda_{n}(\beta-\mu)\right\} \\
\log\pi(\beta|\sigma^{2}) & \propto-\frac{1}{2\sigma^{2}}(\beta-\mu)\Lambda_{n}(\beta-\mu)
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Section
Weighted Least Squares
\end_layout

\begin_layout Subsection
Matrix Rank
\end_layout

\begin_layout Standard
Note that if 
\begin_inset Formula $Z\in\mathbb{R}^{k\times k}$
\end_inset

 and 
\begin_inset Formula $c$
\end_inset

 scalar,
 then 
\begin_inset Formula $\det(cZ)=c^{k}\det\left(Z\right)$
\end_inset

.
 Therefore,
 if 
\begin_inset Formula $\beta|_{\sigma^{2}}\sim\mathcal{N}(\mu,\sigma^{2}\Lambda^{-1})$
\end_inset

,
 then the pdf is 
\begin_inset Formula 
\begin{align*}
\pi\left(\beta\mid\sigma^{2}\right) & =\left(2\pi\right)^{-p/2}\det\left(\sigma^{2}\Lambda^{-1}\right)^{-1/2}\exp\left(-\frac{1}{2}\left(\beta-\mu\right)^{\top}\Lambda\left(\beta-\mu\right)\right)\\
 & =\left(2\pi\sigma^{2}\right)^{-p/2}\left[\det\Lambda^{-1}\right]^{-1/2}\exp\left(-\frac{1}{2}\left(\beta-\mu\right)^{\top}\Lambda\left(\beta-\mu\right)\right)\\
 & =\left(2\pi\sigma^{2}\right)^{-p/2}\left[\det\Lambda^{-1}\right]^{-1/2}\exp\left(-\frac{1}{2}\left(\beta-\mu\right)^{\top}\Lambda\left(\beta-\mu\right)\right)\\
\pi(\beta\mid\sigma^{2}) & \propto\left(\sigma^{2}\right)^{-p/2}\exp\left(-\frac{1}{2}\left(\beta-\mu\right)^{\top}\Lambda\left(\beta-\mu\right)\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Subsection
Problem
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{eqnarray*}
\pi(y\mid\beta,\sigma^{2}) & = & \left[\prod_{i}\left(\frac{1}{\sqrt{2\pi\sigma^{2}/w_{i}}}\right)\right]\exp\left\{ -\frac{1}{2\sigma^{2}}\left(y-X\beta\right)^{\top}W\left(y-X\beta\right)\right\} \\
\pi(y\mid\beta,\sigma^{2}) & \propto & \left(\frac{1}{\sqrt{\sigma^{2}}}\right)^{n}\left[\prod_{i}\sqrt{w_{i}}\right]\exp\left\{ -\frac{1}{2\sigma^{2}}\left(y-X\beta\right)^{\top}W\left(y-X\beta\right)\right\} \\
\log\pi(y\mid\beta,\sigma^{2}) & \propto & -\frac{n}{2}\log\sigma^{2}-\frac{1}{2\sigma^{2}}\left(y-X\beta\right)^{\top}W\left(y-X\beta\right)
\end{eqnarray*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\pi(\sigma^{2})=\frac{b^{a_{0}}}{\Gamma(a_{0})}\frac{1}{\left(\sigma^{2}\right)^{a_{0}+1}}e^{-b_{0}/\sigma^{2}}
\]

\end_inset

so 
\begin_inset Formula 
\[
\log\pi(\sigma^{2})\propto-(a_{0}+1)\log\sigma^{2}-\frac{b_{0}}{\sigma_{2}}
\]

\end_inset

We have 
\begin_inset Formula 
\begin{align*}
\pi\left(\beta\mid\sigma^{2}\right) & =\left(2\pi\right)^{-p/2}\det\left(\sigma^{2}\Lambda_{0}^{-1}\right)^{-1/2}\exp\left\{ -\frac{1}{2\sigma^{2}}\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)\right\} \\
 & =\left(2\pi\right)^{-p/2}\left(\sigma^{2}\right)^{p/2}\det\left(\Lambda_{0}^{-1}\right)^{-1/2}\exp\left\{ -\frac{1}{2\sigma^{2}}\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)\right\} \\
 & \propto\left(\sigma^{2}\right)^{p/2}\exp\left\{ -\frac{1}{2\sigma^{2}}\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)\right\} \\
\log\pi\left(\beta\mid\sigma^{2}\right) & \propto-\frac{p}{2}\log\sigma^{2}-\frac{1}{2\sigma^{2}}\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)
\end{align*}

\end_inset

Putting this all together,
 
\begin_inset Formula 
\begin{eqnarray*}
\log\pi\left(\beta,\sigma^{2}\mid y\right) & \propto & -(a_{0}+1)\log\sigma^{2}-\frac{b_{0}}{\sigma_{2}}\\
 &  & -\frac{p}{2}\log\sigma^{2}-\frac{1}{2\sigma^{2}}\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)\\
 &  & -\frac{n}{2}\log\sigma^{2}-\frac{1}{2\sigma^{2}}\left(y-X\beta\right)^{\top}W\left(y-X\beta\right)\\
 & \propto & -(a_{0}+1)\log\sigma^{2}-\frac{b_{0}}{\sigma_{2}}\\
 &  & -\frac{p}{2}\log\sigma^{2}-\frac{n}{2}\log\sigma^{2}+\frac{1}{2}\sum_{i}\log w_{i}\\
 &  & -\frac{1}{2\sigma^{2}}\underbrace{\left[\left(y-X\beta\right)^{\top}W\left(y-X\beta\right)+\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)\right]}_{Q}
\end{eqnarray*}

\end_inset

Grouping and expanding the quadratic terms,
 
\begin_inset Formula 
\begin{eqnarray*}
Q & = & \left(y-X\beta\right)^{\top}W\left(y-X\beta\right)+\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)\\
 & = & y^{\top}Wy-2y^{\top}WX\beta+\beta^{\top}X^{\top}WX\beta+\beta^{\top}\Lambda_{0}\beta-2\mu_{0}^{\top}\Lambda_{0}\beta+\mu_{0}\Lambda_{0}\mu_{0}\\
 & = & \beta^{\top}\left(X^{\top}WX+\Lambda_{0}\right)\beta-2\left(y^{\top}WX+\mu_{0}^{\top}\Lambda_{0}\right)\beta+\left[y^{\top}Wy+\mu_{0}\Lambda_{0}\mu_{0}\right]
\end{eqnarray*}

\end_inset

Let 
\begin_inset Formula 
\begin{align*}
\Lambda^{*} & =X^{\top}WX+\Lambda_{0}\\
\mu^{*} & =\left(\Lambda^{*}\right)^{-1}\left(y^{\top}WX+\mu_{0}^{\top}\Lambda_{0}\right)
\end{align*}

\end_inset

Note that 
\begin_inset Formula $\mu^{*}$
\end_inset

 minimizes the quadratic from above (in the log-posterior,
 it has a negative coefficient,
 
\begin_inset Formula $-1/2\sigma^{2}$
\end_inset

,
 so 
\begin_inset Formula $\mu^{*}$
\end_inset

 it's a maximizer).
 So 
\begin_inset Formula 
\[
Q=\beta^{\top}\Lambda^{*}\beta-2\left(y^{\top}WX+\mu_{0}^{\top}\Lambda_{0}\right)\beta+\left[y^{\top}Wy+\mu_{0}\Lambda_{0}\mu_{0}\right]
\]

\end_inset

Note that 
\begin_inset Formula 
\begin{align*}
\left(y^{\top}WX+\mu_{0}^{\top}\Lambda_{0}\right) & =\Lambda^{*}\left(\Lambda^{*}\right)^{-1}\left(y^{\top}WX+\mu_{0}^{\top}\Lambda_{0}\right)\\
 & =\Lambda^{*}\mu^{*}
\end{align*}

\end_inset

So
\begin_inset Formula 
\[
Q=\beta^{\top}\Lambda^{*}\beta-2\left(\mu^{*}\right)^{\top}\Lambda^{*}\beta+\left[y^{\top}Wy+\mu_{0}\Lambda_{0}\mu_{0}\right]
\]

\end_inset

(I am being loose with tranposes.) 
\begin_inset Formula 
\begin{align*}
\left(\beta-\mu^{*}\right)^{\top}\Lambda^{*}\left(\beta-\mu^{*}\right) & =\mu^{*}{}^{\top}\Lambda^{*}\beta-2\mu^{*}{}^{\top}\Lambda^{*}\beta+\mu^{*}{}^{\top}\Lambda^{*}\mu^{*}\\
\mu^{*}{}^{\top}\Lambda^{*}\beta & =\left(\beta-\mu^{*}\right)^{\top}\Lambda^{*}\left(\beta-\mu^{*}\right)+2\mu^{*}{}^{\top}\Lambda^{*}\beta-\mu^{*}{}^{\top}\Lambda^{*}\mu^{*}
\end{align*}

\end_inset

So 
\begin_inset Formula 
\begin{align*}
Q & =\left(\beta-\mu^{*}\right)^{\top}\Lambda^{*}\left(\beta-\mu^{*}\right)+2\mu^{*}{}^{\top}\Lambda^{*}\beta-\mu^{*}{}^{\top}\Lambda^{*}\mu^{*}-2\left(\mu^{*}\right)^{\top}\Lambda^{*}\beta+\left[y^{\top}Wy+\mu_{0}\Lambda_{0}\mu_{0}\right]\\
Q & =\left(\beta-\mu^{*}\right)^{\top}\Lambda^{*}\left(\beta-\mu^{*}\right)+\left[y^{\top}Wy+\mu_{0}\Lambda_{0}\mu_{0}-\mu^{*}{}^{\top}\Lambda^{*}\mu^{*}\right]
\end{align*}

\end_inset

Plugging back into our log-posterior
\begin_inset Formula 
\begin{eqnarray*}
\log\pi\left(\beta,\sigma^{2}\mid y\right) & \propto & -(a_{0}+1)\log\sigma^{2}-\frac{b_{0}}{\sigma_{2}}\\
 &  & -\frac{p}{2}\log\sigma^{2}-\frac{n}{2}\log\sigma^{2}\\
 &  & -\frac{1}{2\sigma^{2}}\left[\left(\beta-\mu^{*}\right)^{\top}\Lambda^{*}\left(\beta-\mu^{*}\right)+\left[y^{\top}Wy+\mu_{0}\Lambda_{0}\mu_{0}-\mu^{*}{}^{\top}\Lambda^{*}\mu^{*}\right]\right]\\
 & \propto & -\underbrace{\left(\underbrace{a_{0}+\frac{n-p}{2}}_{a^{*}}+1\right)\log\sigma^{2}-\left(\underbrace{b_{0}+\frac{y^{\top}Wy+\mu_{0}\Lambda_{0}\mu_{0}-\mu^{*}{}^{\top}\Lambda^{*}\mu^{*}}{2}}_{b^{*}}\right)\frac{1}{\sigma^{2}}}_{\text{IG}(a^{*},b^{*})}\\
 &  & \underbrace{-\frac{1}{2\sigma^{2}}\left(\beta-\mu^{*}\right)^{\top}\Lambda^{*}\left(\beta-\mu^{*}\right)}_{\mathcal{N}\left(\mu^{*},\sigma^{2}\left(\Lambda^{*}\right)^{-1}\right)}
\end{eqnarray*}

\end_inset


\end_layout

\begin_layout Subsection*
When 
\begin_inset Formula $\beta\sim\mathcal{N}(0,\Lambda_{0}^{-1})$
\end_inset

 (not dependent on 
\begin_inset Formula $\sigma^{2}$
\end_inset

)
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\log\pi\left(\beta,\sigma^{2}\mid y\right) & \propto-(a_{0}+1)\log\sigma^{2}-\frac{b_{0}}{\sigma_{2}}-\frac{p}{2}\log\sigma^{2}-\frac{1}{2}\left(\beta-\mu_{0}\right)^{\top}\Lambda_{0}\left(\beta-\mu_{0}\right)-\frac{n}{2}\log\sigma^{2}-\frac{1}{2\sigma^{2}}\left(y-X\beta\right)^{\top}W\left(y-X\beta\right)\\
 & \propto-(a_{0}+1)\log\sigma^{2}-\frac{b_{0}}{\sigma_{2}}\\
 & -\frac{p}{2}\log\sigma^{2}-\frac{n}{2}\log\sigma^{2}+\frac{1}{2}\sum_{i}\log w_{i}\\
 & -\frac{1}{2\sigma^{2}}\underbrace{\left[\left(y-X\beta\right)^{\top}W\left(y-X\beta\right)+\left(\beta-\mu_{0}\right)^{\top}\sigma^{2}\Lambda_{0}\left(\beta-\mu_{0}\right)\right]}_{Q(\sigma^{2})}
\end{align*}

\end_inset


\end_layout

